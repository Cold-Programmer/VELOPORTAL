# VeloPortal Frontend Environment Variables
# Copy to .env and fill in your values

# ---- API ----
VITE_API_URL=http://localhost:5000/api

# ---- Google Analytics 4 ----
# Get from: https://analytics.google.com → Admin → Data Streams → Measurement ID
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ---- Google Site Verification (Google Search Console) ----
# Get from: https://search.google.com/search-console → Add Property → HTML tag method
# Copy the "content" attribute value only, e.g. AbCdEfGhIjKlMnOpQrStUvWxYz12345678
VITE_GOOGLE_SITE_VERIFICATION=your-verification-code-here

# ---- Site URL (used in canonical tags and sitemap) ----
VITE_SITE_URL=https://veloportal.app
